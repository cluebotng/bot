{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "automerge": true,
  "automergeStrategy": "rebase",
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["(^|/)composer\\.json$"],
      "matchStrings": ["\"cluebotng/wikipedia\":\\s*\"(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "cluebotng/wikipedia",
      "depNameTemplate": "cluebotng/wikipedia"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["composer"],
      "matchPackageNames": ["cluebotng/wikipedia"],
      "enabled": false
    }
  ]
}
